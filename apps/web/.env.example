# ── Supabase ──────────────────────────────────────────────────
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AgenteFlow API (FastAPI) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Meta Ads ──────────────────────────────────────────────────
NEXT_PUBLIC_META_APP_ID=your-meta-app-id

# ── Stripe ────────────────────────────────────────────────────
# Obtén tus claves en https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — obtenlo en https://dashboard.stripe.com/webhooks
# o con: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de precios en Stripe (crear en Dashboard > Productos)
# Formato: precio mensual por plan
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_BUSINESS_PRO=price_...

# URL pública del sitio (para redirects de Stripe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
